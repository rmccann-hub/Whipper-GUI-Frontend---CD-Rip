# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
dist/
*.egg-info/
*.egg
wheels/

# AppImage build artifacts (the build script outputs to repo root)
*.AppImage
*.AppDir/
AppDir/
build/python-appimage/.cache/
# Intermediate wheel build tree from `python -m build`
build/lib/
# Locally-built wheel staged for python-appimage's PIP_FIND_LINKS
build/python-appimage/*.whl
# Note: build/python-appimage/whipper-gui.png IS committed (the real app icon,
# produced by build/make_icon.py). The build script only generates a
# placeholder if that committed file is ever missing.

# Virtual environments
.venv/
venv/
env/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Copyrighted media — NEVER commit (CLAUDE.md Critical rule #8). This repo is
# public; committing a music file redistributes copyrighted material, even if
# it's only a temporary test file. We commit rip *logs* + per-track CRCs as the
# proof, never the audio. This is a backstop for the rule, not a substitute for
# it. (If you ever need a genuinely free/CC0/self-generated sample, override per
# file with `git add -f` — and be sure it's not a commercial track.)
*.flac
*.wav
*.mp3
*.m4a
*.aac
*.ogg
*.oga
*.opus
*.wv
*.ape
*.wma
*.aiff
*.aif
*.alac
*.dsf
*.dff
