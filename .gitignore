# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
dist/
*.egg-info/
*.egg
wheels/

# AppImage build artifacts (the build script outputs to repo root)
*.AppImage
*.AppDir/
AppDir/
build/python-appimage/.cache/
# Intermediate wheel build tree from `python -m build`
build/lib/
# Locally-built wheel staged for python-appimage's PIP_FIND_LINKS
build/python-appimage/*.whl
# Note: build/python-appimage/whipper-gui.png IS committed (the real app icon,
# produced by build/make_icon.py). The build script only generates a
# placeholder if that committed file is ever missing.

# Virtual environments
.venv/
venv/
env/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
